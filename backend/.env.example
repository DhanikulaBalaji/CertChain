# Copy this file to .env and fill in your values. Never commit .env to git.

# App
# SECRET_KEY=your-super-secret-key-change-in-production

# Blockchain (Ethereum) – required for on-chain certificate hashes
# Private key must be 64 hexadecimal characters (32 bytes). With or without 0x prefix.
# Generate one for development: use a wallet (e.g. MetaMask) or: python -c "from eth_account import Account; print(Account.create().key.hex())"
PRIVATE_KEY=your_64_character_hex_private_key_here_no_spaces
# ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
# CONTRACT_ADDRESS=0x...your_deployed_contract_address

# Optional: email, database overrides, etc.
# DATABASE_URL=sqlite:///./certificate_system.db
